# API
API_PORT=8080
ASPNETCORE_ENVIRONMENT=Development

# PostgreSQL
POSTGRES_PORT=5432
POSTGRES_DB=auth_core
POSTGRES_USER=
POSTGRES_PASSWORD=

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS__KEYPREFIX=authcore:dev

# RabbitMQ
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ__USERNAME=
RABBITMQ__PASSWORD=
RABBITMQ__EMAILVERIFICATIONQUEUE=authcore.email

# JWT
AUTHENTICATION__JWT__ISSUER=authcore-dev
AUTHENTICATION__JWT__AUDIENCE=authcore-dev
AUTHENTICATION__JWT__SIGNINGKEY=
AUTHENTICATION__JWT__ACCESSTOKENLIFETIMEMINUTES=15
