# APIs
AUTHCORE_API_PORT=8081
NOTIFICATIONCORE_API_PORT=8082
GATEWAY_API_PORT=8080
ASPNETCORE_ENVIRONMENT=Development

# PostgreSQL - AuthCore
AUTHCORE_POSTGRES_PORT=5432
AUTHCORE_POSTGRES_DB=auth_core
AUTHCORE_POSTGRES_USER=authcore_local
AUTHCORE_POSTGRES_PASSWORD=authcore_local_password
AUTHCORE_DATABASE_MIGRATIONS_AUTOMIGRATEONSTARTUP=true
AUTHCORE_DATABASE_MIGRATIONS_ENSUREDATABASECREATED=true

# PostgreSQL - NotificationCore
NOTIFICATIONCORE_POSTGRES_PORT=5433
NOTIFICATIONCORE_POSTGRES_DB=notification_core
NOTIFICATIONCORE_POSTGRES_USER=notificationcore_local
NOTIFICATIONCORE_POSTGRES_PASSWORD=notificationcore_local_password
NOTIFICATIONCORE_DATABASE_MIGRATIONS_AUTOMIGRATEONSTARTUP=true
NOTIFICATIONCORE_DATABASE_MIGRATIONS_ENSUREDATABASECREATED=true

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=authcore_local_redis
AUTHCORE_REDIS_KEYPREFIX=authcore:dev

# RabbitMQ
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USERNAME=notification_local
RABBITMQ_PASSWORD=notification_local_password
RABBITMQ_EXCHANGE=notification.requests
RABBITMQ_ROUTING_KEY=notification.email.requested
RABBITMQ_QUEUE=notification.email.requests
RABBITMQ_DEAD_LETTER_QUEUE=notification.email.requests.dlq

# SMTP local
SMTP_HOST=smtp
SMTP_CONTAINER_PORT=25
SMTP_PORT=1025
SMTP_WEB_PORT=1080
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_SENDER_EMAIL=no-reply@authcore.local
SMTP_SENDER_NAME=AuthCore Local
SMTP_TIMEOUT_SECONDS=30

# JWT
AUTHENTICATION_JWT_ISSUER=authcore-dev
AUTHENTICATION_JWT_AUDIENCE=authcore-dev
AUTHENTICATION_JWT_SIGNINGKEY=development-authcore-signing-key-0001
AUTHENTICATION_JWT_ACCESSTOKENLIFETIMEMINUTES=5
AUTHENTICATION_JWT_REFRESHTOKENLIFETIMEDAYS=7
AUTHENTICATION_JWT_CLOCKSKEWSECONDS=60

# Browser authentication cookies / CSRF
AUTH_COOKIE_SESSION_COOKIE_NAME=sid
AUTH_COOKIE_ACCESS_TOKEN_COOKIE_NAME=at
AUTH_CSRF_SIGNING_KEY=development-authcore-csrf-signing-key-0001
AUTH_CSRF_ALLOWED_ORIGIN_0=http://localhost:3000
AUTH_CSRF_ALLOWED_ORIGIN_1=http://127.0.0.1:3000
AUTH_CSRF_ALLOWED_ORIGIN_2=http://localhost:5173
AUTH_CSRF_ALLOWED_ORIGIN_3=http://127.0.0.1:5173

# Workers
AUTHCORE_OUTBOX_ENABLED=true
AUTHCORE_OUTBOX_BATCH_SIZE=20
AUTHCORE_OUTBOX_POLLING_INTERVAL_SECONDS=10
AUTHCORE_OUTBOX_MAX_ATTEMPTS=5
NOTIFICATIONCORE_RABBITMQ_CONSUMER_ENABLED=true
NOTIFICATIONCORE_DISPATCHER_ENABLED=true
NOTIFICATIONCORE_DISPATCHER_BATCH_SIZE=20
NOTIFICATIONCORE_DISPATCHER_POLLING_INTERVAL_SECONDS=10
NOTIFICATIONCORE_DISPATCHER_RETRY_DELAY_SECONDS=300
NOTIFICATIONCORE_DISPATCHER_PROCESSING_TIMEOUT_SECONDS=900
