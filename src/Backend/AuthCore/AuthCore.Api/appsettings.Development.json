{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "PostgreSql": "Host=localhost;Port=5432;Database=auth_core;Username=authcore_local;Password=authcore_local_password;Pooling=true"
  },
  "Database": {
    "Migrations": {
      "AutoMigrateOnStartup": true,
      "EnsureDatabaseCreated": true,
      "AdminDatabase": "postgres"
    }
  },
  "Authentication": {
    "Jwt": {
      "Issuer": "authcore-dev",
      "Audience": "authcore-dev",
      "SigningKey": "development-authcore-signing-key-0001",
      "AccessTokenLifetimeMinutes": 15,
      "RefreshTokenLifetimeDays": 7,
      "ClockSkewSeconds": 60
    }
  },
  "Redis": {
    "ConnectionString": "localhost:6379,password=authcore_local_redis,abortConnect=false",
    "KeyPrefix": "authcore:dev"
  },
  "ReverseProxy": {
    "KnownProxies": [],
    "KnownNetworks": [],
    "ForwardLimit": 2
  },
  "Auth": {
    "Cookie": {
      "SessionCookieName": "sid",
      "Secure": false
    },
    "Csrf": {
      "AllowedOrigins": [
        "http://localhost:3000",
        "http://127.0.0.1:3000",
        "http://localhost:5173",
        "http://127.0.0.1:5173"
      ]
    },
    "LoginRateLimit": {
      "MaxAttemptsPerIp": 20,
      "MaxAttemptsPerEmail": 5,
      "WindowMinutes": 5
    },
    "Session": {
      "TtlMinutes": 120,
      "SlidingTtl": true
    }
  },
  "RabbitMq": {
    "Host": "localhost",
    "Port": 5672,
    "VirtualHost": "/",
    "Username": "notification_local",
    "Password": "notification_local_password",
    "Exchange": "notification.requests",
    "RoutingKey": "notification.email.requested",
    "Queue": "notification.email.requests",
    "DeadLetterQueue": "notification.email.requests.dlq"
  },
  "Outbox": {
    "Enabled": true,
    "BatchSize": 20,
    "PollingIntervalSeconds": 10,
    "MaxAttempts": 5
  }
}
