{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "PostgreSql": "Host=localhost;Port=5433;Database=notification_core;Username=notificationcore_local;Password=notificationcore_local_password;Pooling=true"
  },
  "Database": {
    "Migrations": {
      "AutoMigrateOnStartup": true,
      "EnsureDatabaseCreated": true,
      "AdminDatabase": "postgres"
    }
  },
  "RabbitMq": {
    "Enabled": true,
    "Host": "localhost",
    "Port": 5672,
    "VirtualHost": "/",
    "Username": "notification_local",
    "Password": "notification_local_password",
    "Exchange": "notification.requests",
    "RoutingKey": "notification.email.requested",
    "Queue": "notification.email.requests",
    "DeadLetterQueue": "notification.email.requests.dlq"
  },
  "Smtp": {
    "Host": "localhost",
    "Port": 1025,
    "Username": "",
    "Password": "",
    "UseTls": false,
    "SenderEmail": "no-reply@authcore.local",
    "SenderName": "AuthCore Local",
    "TimeoutSeconds": 30
  },
  "NotificationDispatcher": {
    "Enabled": true,
    "BatchSize": 20,
    "PollingIntervalSeconds": 10,
    "RetryDelaySeconds": 300,
    "ProcessingTimeoutSeconds": 900
  }
}
